{
    "name": "ilbronza/accountmanager",
    "description": ":package_description",
    "license": "MIT",
    "authors": [
        {
            "name": "Davide Bronzini",
            "email": "davide_bronzini@hotmail.com",
            "homepage": "https://www.sistema.srl"
        }
    ],
    "homepage": "https://github.com/ilbronza/accountmanager",
    "keywords": ["Laravel", "AccountManager"],
    "require": {
        "laravel/ui": "^4.6"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-activitylog": "^4.0|^5.0",
        "ilbronza/crud": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "IlBronza\\AccountManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IlBronza\\AccountManager\\Tests\\": "tests",
            "App\\": "tests/App/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IlBronza\\AccountManager\\AccountManagerServiceProvider"
            ],
            "aliases": {
                "AccountManager": "IlBronza\\AccountManager\\Facades\\AccountManager"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
